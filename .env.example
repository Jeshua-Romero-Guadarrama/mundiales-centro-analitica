# Copia este archivo como ".env" y rellena tu clave (opcional).
#
# football-data.org ofrece una API gratuita. Registrate aqui para obtener
# tu token gratis:  https://www.football-data.org/client/register
#
# Si NO pones clave, la app funciona igual: usara scraping de Wikipedia
# y un dataset semilla de los 48 equipos para que los modelos funcionen.

FOOTBALL_DATA_API_KEY=

# Hora (formato 24h, hora local) a la que se actualizan los datos cada dia.
DAILY_UPDATE_HOUR=6
DAILY_UPDATE_MINUTE=0
